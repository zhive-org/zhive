{
	"$schema": "https://turborepo.dev/schema.json",
	"ui": "tui",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"]
		},
		"lint": {
			"dependsOn": ["^lint"]
		},
		"check-types": {
			"dependsOn": ["^check-types"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"test": {
			"dependsOn": ["^build"],
			"inputs": [
				"src/**",
				"**/*.test.ts",
				"**/*.test.tsx",
				"**/*.spec.ts",
				"vitest.config.ts",
				"tsconfig.json"
			],
			"outputs": ["coverage/**", ".vitest/**"],
			"cache": true
		}
	}
}
